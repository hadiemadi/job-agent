ANTHROPIC_API_KEY=your_anthropic_api_key_here
RAPIDAPI_KEY=your_rapidapi_key_here
JOOBLE_KEY=your_jooble_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# ── Auth / user accounts (routes/auth.routes.js, core/passport.js) ─────────────
# Required in Render dashboard before enabling Google OAuth sign-in.
# Create a project at console.cloud.google.com, enable "Google+ API", add an OAuth
# 2.0 client ID of type "Web application", and set the callback URL to your Render
# service URL + /auth/google/callback (e.g. https://jobseeker-rpzr.onrender.com/auth/google/callback).
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_CALLBACK_URL=https://your-render-service.onrender.com/auth/google/callback
# SESSION_SECRET is used for cookie signing. Set a long random string in Render.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=generate_a_random_32_byte_hex_string

# ── Cost & abuse protection (see core/claude.js, services/ratelimit.js, src/jobs.js) ──
# Hard daily ceiling on estimated Anthropic spend (USD). Once today's running total hits
# this, every further Anthropic call is rejected until the next UTC day. In-memory only —
# resets on server restart too; a DB-backed counter is the future hardening step.
DAILY_AI_BUDGET_USD=5
# Per-million-token prices used to estimate cost from response.usage. Set these to the
# CURRENT Claude Sonnet 4.6 prices (USD per 1,000,000 tokens) — defaults below match the
# published Sonnet 4.6 rate as of when this was written; re-check if the model/pricing changes.
ANTHROPIC_PRICE_INPUT_PER_MTOK=3
ANTHROPIC_PRICE_OUTPUT_PER_MTOK=15
# Broad, app-wide per-user (per "sid" cookie) rate limit.
RATE_LIMIT_WINDOW_MIN=15
RATE_LIMIT_MAX=100
# Stricter per-user limit on the AI/job-search-heavy routes, per hour.
AI_RATE_LIMIT_MAX=20
# Server-wide (not per-user) cap on job-search calls per UTC day, to protect RapidAPI/Jooble spend.
DAILY_JOB_SEARCH_CAP=50

# ── Privacy (see services/session.js) ──────────────────────────────────────────────
# How long a generated CV/cover-letter/comparison file may sit in output/ before the
# periodic sweep deletes it, even if the session that made it is still active. The source
# CV upload itself is deleted immediately after its text is extracted — this only governs
# the generated output files.
OUTPUT_RETENTION_MINUTES=180
