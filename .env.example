ANTHROPIC_API_KEY=your_anthropic_api_key_here
RAPIDAPI_KEY=your_rapidapi_key_here
JOOBLE_KEY=your_jooble_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# ── Cost & abuse protection (see core/claude.js, services/ratelimit.js, src/jobs.js) ──
# Hard daily ceiling on estimated Anthropic spend (USD). Once today's running total hits
# this, every further Anthropic call is rejected until the next UTC day. In-memory only —
# resets on server restart too; a DB-backed counter is the future hardening step.
DAILY_AI_BUDGET_USD=5
# Per-million-token prices used to estimate cost from response.usage. Set these to the
# CURRENT Claude Sonnet 4.6 prices (USD per 1,000,000 tokens) — defaults below match the
# published Sonnet 4.6 rate as of when this was written; re-check if the model/pricing changes.
ANTHROPIC_PRICE_INPUT_PER_MTOK=3
ANTHROPIC_PRICE_OUTPUT_PER_MTOK=15
# Broad, app-wide per-user (per "sid" cookie) rate limit.
RATE_LIMIT_WINDOW_MIN=15
RATE_LIMIT_MAX=100
# Stricter per-user limit on the AI/job-search-heavy routes, per hour.
AI_RATE_LIMIT_MAX=20
# Server-wide (not per-user) cap on job-search calls per UTC day, to protect RapidAPI/Jooble spend.
DAILY_JOB_SEARCH_CAP=50
